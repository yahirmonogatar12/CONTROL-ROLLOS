      FROM materiales 
      ORDER BY codigo_material
    `);
    res.json(rows);
  } catch (err) {
    next(err);
  }
});

// POST /api/materiales - Crear nuevo material
app.post('/api/materiales', async (req, res, next) => {
  try {
    const {
      numero_parte,
      codigo_material,
      propiedad_material,
      clasificacion,
      especificacion_material,
      unidad_empaque,
      ubicacion_material,
      vendedor,
      prohibido_sacar,
      nivel_msl,
      espesor_msl,
      assign_internal_lot,
      usuario_registro,
      version
    } = req.body;

    // Validar campos requeridos
    if (!numero_parte || !codigo_material || !propiedad_material || !especificacion_material || !unidad_empaque) {
      return res.status(400).json({ 
        error: 'Campos requeridos faltantes: numero_parte, codigo_material, propiedad_material, especificacion_material, unidad_empaque',
        code: 'MISSING_REQUIRED_FIELDS'
      });
    }

    // Verificar si ya existe el numero_parte
    const [existing] = await pool.query(
      'SELECT numero_parte FROM materiales WHERE numero_parte = ?',
      [numero_parte]
    );

    if (existing.length > 0) {
      return res.status(400).json({ 
        error: 'El número de parte ya existe',
        code: 'DUPLICATE_PART_NUMBER'
      });
    }

    // Insertar nuevo material
    await pool.query(`
      INSERT INTO materiales (
        numero_parte, codigo_material, propiedad_material, clasificacion,
        especificacion_material, unidad_empaque, ubicacion_material, vendedor,
        prohibido_sacar, nivel_msl, espesor_msl, fecha_registro,
        usuario_registro, iqc_required, assign_internal_lot, version
      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, NOW(), ?, 0, ?, ?)
    `, [
      numero_parte,
      codigo_material,
      propiedad_material,
      clasificacion || null,
      especificacion_material,
      unidad_empaque,
      ubicacion_material || null,
      vendedor || null,
      prohibido_sacar || 0,
      nivel_msl || null,
      espesor_msl || null,
      usuario_registro || null,
      assign_internal_lot || 0,
      version || null
    ]);

    res.status(201).json({ message: 'Material creado exitosamente', numero_parte });
  } catch (err) {
    next(err);
  }
});

// PUT /api/materiales/:numeroParte - Actualizar material existente
app.put('/api/materiales/:numeroParte', async (req, res, next) => {
  try {
    const { numeroParte } = req.params;
    const {
      codigo_material,
      propiedad_material,
      clasificacion,
      especificacion_material,
      unidad_empaque,
      ubicacion_material,
      vendedor,
      prohibido_sacar,
      nivel_msl,
      espesor_msl,
      assign_internal_lot,
      usuario_registro,
      version
    } = req.body;

    // Validar campos requeridos
    if (!codigo_material || !propiedad_material || !especificacion_material || !unidad_empaque) {
      return res.status(400).json({ 
        error: 'Campos requeridos faltantes: codigo_material, propiedad_material, especificacion_material, unidad_empaque',
        code: 'MISSING_REQUIRED_FIELDS'
      });
    }

    // Verificar si existe el material
    const [existing] = await pool.query(
      'SELECT numero_parte FROM materiales WHERE numero_parte = ?',
      [numeroParte]
    );

    if (existing.length === 0) {
      return res.status(404).json({ 
        error: 'Material no encontrado',
        code: 'NOT_FOUND'
      });
    }

    // Actualizar material (no se actualiza numero_parte, iqc_required ni fecha_registro)
    await pool.query(`
      UPDATE materiales SET
        codigo_material = ?,
        propiedad_material = ?,
        clasificacion = ?,
        especificacion_material = ?,
        unidad_empaque = ?,
        ubicacion_material = ?,
        vendedor = ?,
        prohibido_sacar = ?,
        nivel_msl = ?,
        espesor_msl = ?,
        assign_internal_lot = ?,
        usuario_registro = ?,
        version = ?
      WHERE numero_parte = ?
    `, [
      codigo_material,
      propiedad_material,
      clasificacion || null,
      especificacion_material,
      unidad_empaque,
      ubicacion_material || null,
      vendedor || null,
      prohibido_sacar || 0,
      nivel_msl || null,
      espesor_msl || null,
      assign_internal_lot || 0,
      usuario_registro || null,
      version || null,
      numeroParte
    ]);

    res.json({ message: 'Material actualizado exitosamente', numero_parte: numeroParte });
  } catch (err) {
    next(err);
  }
});

// DELETE /api/materiales/:numeroParte - Eliminar material
app.delete('/api/materiales/:numeroParte', async (req, res, next) => {
  try {
    const { numeroParte } = req.params;

    // Verificar si existe el material
    const [existing] = await pool.query(
      'SELECT numero_parte FROM materiales WHERE numero_parte = ?',
      [numeroParte]
    );

    if (existing.length === 0) {
      return res.status(404).json({ 
        error: 'Material no encontrado',
        code: 'NOT_FOUND'
      });
    }

    // Eliminar material
    await pool.query('DELETE FROM materiales WHERE numero_parte = ?', [numeroParte]);

    res.json({ message: 'Material eliminado exitosamente', numero_parte: numeroParte });
  } catch (err) {
    next(err);
  }
});

// ============================================
// RUTAS - CONTROL MATERIAL SALIDA (Salida de Material)
// ============================================

// GET /api/outgoing/check-salida/:code - Verificar si un material ya tiene salida
app.get('/api/outgoing/check-salida/:code', async (req, res, next) => {
  try {
    const { code } = req.params;
    
    const [rows] = await pool.query(`
      SELECT tiene_salida 
      FROM control_material_almacen 
      WHERE codigo_material_recibido = ?
      LIMIT 1
    `, [code]);

    if (rows.length === 0) {
      return res.status(404).json({ error: 'Material no encontrado', has_outgoing: false });
    }

    const tieneSalida = rows[0].tiene_salida === 1;
    res.json({ 
      has_outgoing: tieneSalida,
      code: code
    });
  } catch (err) {
    next(err);
  }
});

// GET /api/outgoing/locations-by-partnumber - Obtener ubicaciones para múltiples part numbers
app.get('/api/outgoing/locations-by-partnumber', async (req, res, next) => {
  try {
    const { partNumbers } = req.query;
    
    if (!partNumbers) {
      return res.json({});
    }

    // partNumbers viene como string separado por comas
    const partNumberList = partNumbers.split(',').map(p => p.trim()).filter(p => p);
    
    if (partNumberList.length === 0) {
      return res.json({});
    }

    // Consultar ubicaciones donde cancelado=0 AND tiene_salida=0
    const placeholders = partNumberList.map(() => '?').join(',');
    const [rows] = await pool.query(`
      SELECT numero_parte, ubicacion_salida 
      FROM control_material_almacen 
      WHERE numero_parte IN (${placeholders})
        AND (cancelado = 0 OR cancelado IS NULL)
        AND (tiene_salida = 0 OR tiene_salida IS NULL)
      ORDER BY numero_parte
    `, partNumberList);

    // Agrupar ubicaciones por part number
    const locationsByPartNumber = {};
    rows.forEach(row => {
      const partNumber = row.numero_parte;
      const location = row.ubicacion_salida || '';
      
      if (!locationsByPartNumber[partNumber]) {
        locationsByPartNumber[partNumber] = [];
      }
      
      if (location && !locationsByPartNumber[partNumber].includes(location)) {
        locationsByPartNumber[partNumber].push(location);
      }
    });

    res.json(locationsByPartNumber);
  } catch (err) {
    next(err);
  }
});

// POST /api/outgoing - Crea nuevo registro de salida
app.post('/api/outgoing', async (req, res, next) => {
  try {
    const {
      codigo_material_recibido,
      numero_parte,
      numero_lote,
      modelo,
      depto_salida,
      proceso_salida,
      cantidad_salida,
      especificacion_material,
      usuario_registro
    } = req.body;

    // Verificar si el material ya tiene salida
    const [checkRows] = await pool.query(`
      SELECT tiene_salida 
      FROM control_material_almacen 
      WHERE codigo_material_recibido = ?
      LIMIT 1
    `, [codigo_material_recibido]);

    if (checkRows.length > 0 && checkRows[0].tiene_salida === 1) {
      return res.status(400).json({ 
        error: 'Este material ya tiene una salida registrada',
        code: 'ALREADY_HAS_OUTGOING'
      });
    }

    // Usar fecha_salida del cliente (hora local de la PC) o NOW() como fallback
    const fecha_salida = req.body.fecha_salida || null;
    
    const [result] = await pool.query(`
      INSERT INTO control_material_salida (
        codigo_material_recibido,
        numero_parte,
        numero_lote,
        modelo,
        depto_salida,
        proceso_salida,
        cantidad_salida,
        fecha_salida,
        fecha_registro,
        especificacion_material,
        usuario_registro
      ) VALUES (?, ?, ?, ?, ?, ?, ?, ${fecha_salida ? '?' : 'NOW()'}, NOW(), ?, ?)
    `, fecha_salida ? [
      codigo_material_recibido,
      numero_parte,
      numero_lote,
      modelo,
      depto_salida,
      proceso_salida,
      cantidad_salida,
      fecha_salida,
      especificacion_material,
      usuario_registro
    ] : [
      codigo_material_recibido,
      numero_parte,
      numero_lote,
      modelo,
      depto_salida,
      proceso_salida,
      cantidad_salida,
      especificacion_material,
      usuario_registro
    ]);

    // Marcar el material como que tiene salida en control_material_almacen
    await pool.query(`
      UPDATE control_material_almacen 
      SET tiene_salida = 1 
      WHERE codigo_material_recibido = ?
    `, [codigo_material_recibido]);

    res.status(201).json({
      id: result.insertId,
      message: 'Registro de salida creado exitosamente'
    });
  } catch (err) {
    next(err);
  }
});

// GET /api/outgoing - Lista todos los registros de salida
app.get('/api/outgoing', async (req, res, next) => {
  try {
    const [rows] = await pool.query(`
      SELECT * FROM control_material_salida 
      ORDER BY fecha_registro DESC
    `);
    res.json(rows);
  } catch (err) {
    next(err);
  }
});

// GET /api/outgoing/search - Buscar salidas por rango de fechas y/o texto
app.get('/api/outgoing/search', async (req, res, next) => {
  try {
    const { fecha_inicio, fecha_fin, texto } = req.query;
    let query = 'SELECT * FROM control_material_salida WHERE 1=1';
    const params = [];

    if (fecha_inicio && fecha_fin) {
      query += ' AND DATE(fecha_salida) BETWEEN ? AND ?';
      params.push(fecha_inicio, fecha_fin);
    }
    
    if (texto) {
      query += ` AND (
        codigo_material_recibido LIKE ? OR
        numero_parte LIKE ? OR
        numero_lote LIKE ? OR
        modelo LIKE ? OR
        depto_salida LIKE ? OR
        proceso_salida LIKE ? OR
        especificacion_material LIKE ?
      )`;
      const searchTerm = `%${texto}%`;
      params.push(searchTerm, searchTerm, searchTerm, searchTerm, searchTerm, searchTerm, searchTerm);
    }

    query += ' ORDER BY fecha_salida DESC';

    const [rows] = await pool.query(query, params);
    res.json(rows);
  } catch (err) {
    next(err);
  }
});

// ============================================
// RUTAS - INVENTARIO LOTES (Current Inventory)
// ============================================

// GET /api/inventory/summary - Inventario general agrupado por numero_parte
app.get('/api/inventory/summary', async (req, res, next) => {
  try {
    const { numero_parte } = req.query;
    
    let query = `
      SELECT
        numero_parte,
        SUM(stock_actual) AS stock_total,
        COUNT(DISTINCT numero_lote) AS lotes_distintos,
        SUM(CASE WHEN stock_actual > 0 THEN 1 ELSE 0 END) AS lotes_con_stock
      FROM inventario_lotes
    `;
    
    const params = [];
    
    if (numero_parte) {
      query += ` WHERE numero_parte LIKE ?`;
      params.push(`%${numero_parte}%`);
    }
    
    query += ` GROUP BY numero_parte HAVING stock_total > 0 ORDER BY numero_parte`;
    
    const [rows] = await pool.query(query, params);
    res.json(rows);
  } catch (err) {
    next(err);
  }
});

// GET /api/inventory/lots - Detalle de lotes por numero_parte
app.get('/api/inventory/lots', async (req, res, next) => {
  try {
    const { numero_parte, codigo_material_recibido } = req.query;
    
    let query = `
      SELECT
        il.numero_parte,
        il.numero_lote,
        il.codigo_material_recibido,
        il.total_entrada,
        il.total_salida,
        il.stock_actual,
        cma.id as warehousing_id,
        cma.codigo_material,
        COALESCE(cma.en_cuarentena, 0) as in_quarantine
      FROM inventario_lotes il
      LEFT JOIN control_material_almacen cma ON il.codigo_material_recibido = cma.codigo_material_recibido
      WHERE il.stock_actual > 0
    `;
    
    const params = [];
    
    if (numero_parte) {
      query += ` AND il.numero_parte LIKE ?`;
      params.push(`%${numero_parte}%`);
    }
    
    if (codigo_material_recibido) {
      query += ` AND il.codigo_material_recibido LIKE ?`;
      params.push(`%${codigo_material_recibido}%`);
    }
    
    query += ` ORDER BY il.numero_parte, il.numero_lote`;
    
    const [rows] = await pool.query(query, params);
    res.json(rows);
  } catch (err) {
    next(err);
  }
});

// GET /api/inventory/search-label - Buscar por etiqueta (codigo_material_recibido)
app.get('/api/inventory/search-label', async (req, res, next) => {
