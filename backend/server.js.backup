// PUT - Actualizar configuración IQC de un material
app.put('/api/materiales/:numeroParte/iqc-config', async (req, res, next) => {
  try {
    const { numeroParte } = req.params;
    const body = req.body;
    
    // Lista de campos permitidos
    const allowedFields = [
      'iqc_required',
      // RoHS
      'rohs_enabled', 'rohs_sampling_level', 'rohs_aql_level',
      // Brightness
      'brightness_enabled', 'brightness_sampling_level', 'brightness_aql_level',
      'brightness_target', 'brightness_lsl', 'brightness_usl',
      // Dimension
      'dimension_enabled', 'dimension_sampling_level', 'dimension_aql_level',
      'dimension_length', 'dimension_length_tol',
      'dimension_width', 'dimension_width_tol',
      'dimension_height', 'dimension_height_tol',
      // Color
      'color_enabled', 'color_sampling_level', 'color_aql_level', 'color_spec',
      // Appearance
      'appearance_enabled', 'appearance_sampling_level', 'appearance_aql_level', 'appearance_spec',
      // Legacy
      'sampling_level', 'aql_level', 'dimension_spec'
    ];
    
    // Construir update dinámico
    const updates = [];
    const values = [];
    
    for (const field of allowedFields) {
      if (body[field] !== undefined) {
        updates.push(`${field} = ?`);
        values.push(body[field]);
      }
    }
    
    if (updates.length === 0) {
      return res.status(400).json({ success: false, message: 'No fields to update' });
    }
    
    values.push(numeroParte);
    
    await pool.query(
      `UPDATE materiales SET ${updates.join(', ')} WHERE numero_parte = ?`,
      values
    );
    
    res.json({ success: true, message: 'Configuration updated' });
  } catch (err) { next(err); }
});

// POST - Bulk update configuración IQC
app.post('/api/materiales/iqc-config/bulk', async (req, res, next) => {
  try {
    const { configs } = req.body;
    if (!Array.isArray(configs)) {
      return res.status(400).json({ error: 'configs must be an array' });
    }
    
    let updated = 0;
    const errors = [];
    
    for (const config of configs) {
      try {
        if (!config.numero_parte) continue;
        
        const updates = [];
        const values = [];
        
        if (config.iqc_required !== undefined) { updates.push('iqc_required = ?'); values.push(config.iqc_required); }
        if (config.sampling_level !== undefined) { updates.push('sampling_level = ?'); values.push(config.sampling_level); }
        if (config.aql_level !== undefined) { updates.push('aql_level = ?'); values.push(config.aql_level); }
        if (config.rohs_enabled !== undefined) { updates.push('rohs_enabled = ?'); values.push(config.rohs_enabled); }
        if (config.brightness_enabled !== undefined) { updates.push('brightness_enabled = ?'); values.push(config.brightness_enabled); }
        if (config.dimension_enabled !== undefined) { updates.push('dimension_enabled = ?'); values.push(config.dimension_enabled); }
        if (config.color_enabled !== undefined) { updates.push('color_enabled = ?'); values.push(config.color_enabled); }
        if (config.brightness_target !== undefined) { updates.push('brightness_target = ?'); values.push(config.brightness_target); }
        if (config.brightness_lsl !== undefined) { updates.push('brightness_lsl = ?'); values.push(config.brightness_lsl); }
        if (config.brightness_usl !== undefined) { updates.push('brightness_usl = ?'); values.push(config.brightness_usl); }
        if (config.dimension_spec !== undefined) { updates.push('dimension_spec = ?'); values.push(config.dimension_spec); }
        
        if (updates.length > 0) {
          values.push(config.numero_parte);
          await pool.query(
            `UPDATE materiales SET ${updates.join(', ')} WHERE numero_parte = ?`,
            values
          );
          updated++;
        }
      } catch (e) {
        errors.push({ numero_parte: config.numero_parte, error: e.message });
      }
    }
    
    res.json({ success: true, updated, errors, total: configs.length });
  } catch (err) { next(err); }
});

// ============================================
// QUARANTINE (CUARENTENA) - CRUD
// ============================================

// Crear tablas de cuarentena si no existen
async function createQuarantineTablesIfNotExist() {
  try {
    // Tabla principal de cuarentena
    await pool.query(`
      CREATE TABLE IF NOT EXISTS quarantine (
        id INT AUTO_INCREMENT PRIMARY KEY,
        warehousing_id INT NULL,
        codigo_material_recibido VARCHAR(50) NOT NULL,
        part_number VARCHAR(150) NULL,
        material_code TEXT NULL,
        cantidad INT DEFAULT 0,
        especificacion TEXT NULL,
        ubicacion_original VARCHAR(50) NULL,
        reason TEXT NULL,
        status ENUM('InQuarantine','Released','Scrapped','Returned') DEFAULT 'InQuarantine',
        created_by_id INT NULL,
        created_by_name VARCHAR(100) NULL,
        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
        closed_at DATETIME NULL,
        closed_by_id INT NULL,
        closed_by_name VARCHAR(100) NULL,
        INDEX idx_quarantine_status (status),
        INDEX idx_quarantine_codigo (codigo_material_recibido),
        INDEX idx_quarantine_part (part_number)
      )
    `);
    
    // Tabla de historial de cambios en cuarentena
    await pool.query(`
      CREATE TABLE IF NOT EXISTS quarantine_history (
        id INT AUTO_INCREMENT PRIMARY KEY,
        quarantine_id INT NOT NULL,
        action ENUM('Created','StatusChanged','CommentAdded','Released','Scrapped','Returned') NOT NULL,
        old_status VARCHAR(50) NULL,
        new_status VARCHAR(50) NULL,
        comments TEXT NULL,
        action_by_id INT NULL,
        action_by_name VARCHAR(100) NULL,
        action_at DATETIME DEFAULT CURRENT_TIMESTAMP,
        INDEX idx_qh_quarantine (quarantine_id),
        FOREIGN KEY (quarantine_id) REFERENCES quarantine(id) ON DELETE CASCADE
      )
    `);
    
    // Agregar columna en_cuarentena a control_material_almacen
    const [cols] = await pool.query(`
      SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS 
      WHERE TABLE_SCHEMA = DATABASE() 
      AND TABLE_NAME = 'control_material_almacen' 
      AND COLUMN_NAME = 'en_cuarentena'
    `);
    
    if (cols.length === 0) {
      await pool.query(`ALTER TABLE control_material_almacen ADD COLUMN en_cuarentena TINYINT DEFAULT 0`);
      console.log('✓ Columna "en_cuarentena" agregada a control_material_almacen');
    }
    
    console.log('✓ Tablas de cuarentena verificadas/creadas');
  } catch (err) {
    console.error('Error creando tablas de cuarentena:', err.message);
  }
}
createQuarantineTablesIfNotExist();

// GET - Obtener materiales en cuarentena
app.get('/api/quarantine', async (req, res, next) => {
  try {
    const { status } = req.query;
    let query = `SELECT * FROM quarantine`;
    const params = [];
    
    if (status) {
      query += ` WHERE status = ?`;
      params.push(status);
    }
    
    query += ` ORDER BY created_at DESC`;
    
    const [rows] = await pool.query(query, params);
    res.json(rows);
  } catch (err) { next(err); }
});

// GET - Obtener historial de un item de cuarentena
app.get('/api/quarantine/:id/history', async (req, res, next) => {
  try {
    const { id } = req.params;
    const [rows] = await pool.query(
      `SELECT * FROM quarantine_history WHERE quarantine_id = ? ORDER BY action_at DESC`,
      [id]
    );
    res.json(rows);
  } catch (err) { next(err); }
});

// GET - Historial completo de cuarentena (items cerrados)
app.get('/api/quarantine/history/all', async (req, res, next) => {
  try {
    const { fecha_inicio, fecha_fin } = req.query;
    let query = `SELECT q.*, 
                   (SELECT COUNT(*) FROM quarantine_history WHERE quarantine_id = q.id) as history_count
                 FROM quarantine q 
                 WHERE q.status != 'InQuarantine'`;
    const params = [];
    
    if (fecha_inicio && fecha_fin) {
      query += ` AND DATE(q.closed_at) BETWEEN ? AND ?`;
      params.push(fecha_inicio, fecha_fin);
    }
    
    query += ` ORDER BY q.closed_at DESC`;
    
    const [rows] = await pool.query(query, params);
    res.json(rows);
  } catch (err) { next(err); }
});

// POST - Enviar materiales a cuarentena (bulk)
app.post('/api/quarantine/send', async (req, res, next) => {
  try {
    const { items, reason, userId, userName } = req.body;
    
    if (!items || !Array.isArray(items) || items.length === 0) {
      return res.status(400).json({ error: 'No items provided' });
    }
    
    const created = [];
    const errors = [];
    
    for (const item of items) {
      try {
        // Verificar que el material existe y no está ya en cuarentena
        const [existing] = await pool.query(
          `SELECT id, en_cuarentena FROM control_material_almacen WHERE codigo_material_recibido = ?`,
          [item.codigo_material_recibido]
        );
        
        if (existing.length === 0) {
          errors.push({ codigo: item.codigo_material_recibido, error: 'Material not found' });
          continue;
        }
        
        if (existing[0].en_cuarentena === 1) {
          errors.push({ codigo: item.codigo_material_recibido, error: 'Already in quarantine' });
          continue;
        }
        
        // Insertar en cuarentena
        const [result] = await pool.query(
          `INSERT INTO quarantine (
            warehousing_id, codigo_material_recibido, part_number, material_code,
            cantidad, especificacion, ubicacion_original, reason,
            created_by_id, created_by_name
          ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
          [
            item.id || existing[0].id,
            item.codigo_material_recibido,
            item.numero_parte || item.part_number,
            item.codigo_material || item.material_code,
            item.cantidad_actual || item.cantidad || 0,
            item.especificacion,
            item.ubicacion_salida || item.ubicacion_original,
            reason,
            userId,
            userName
          ]
        );
        
        const quarantineId = result.insertId;
        
        // Registrar en historial
        await pool.query(
          `INSERT INTO quarantine_history (quarantine_id, action, new_status, comments, action_by_id, action_by_name)
           VALUES (?, 'Created', 'InQuarantine', ?, ?, ?)`,
          [quarantineId, reason, userId, userName]
        );
        
        // Marcar material como en cuarentena
        await pool.query(
          `UPDATE control_material_almacen SET en_cuarentena = 1 WHERE codigo_material_recibido = ?`,
          [item.codigo_material_recibido]
        );
        
        created.push({ id: quarantineId, codigo: item.codigo_material_recibido });
      } catch (e) {
        errors.push({ codigo: item.codigo_material_recibido, error: e.message });
      }
    }
    
    res.status(201).json({ 
      success: true, 
      created: created.length, 
      errors: errors.length,
      createdItems: created,
      errorItems: errors 
    });
  } catch (err) { next(err); }
});

// PUT - Actualizar estado de cuarentena
app.put('/api/quarantine/:id', async (req, res, next) => {
  try {
    const { id } = req.params;
    const { status, comments, userId, userName } = req.body;
    
    // Obtener estado actual y datos del material
    const [current] = await pool.query(
      `SELECT status, codigo_material_recibido, cantidad FROM quarantine WHERE id = ?`, 
      [id]
    );
    if (current.length === 0) {
      return res.status(404).json({ error: 'Quarantine item not found' });
    }
    
    const oldStatus = current[0].status;
    const codigo = current[0].codigo_material_recibido;
    const cantidad = current[0].cantidad || 0;
    
    // Determinar acción
    let action = 'StatusChanged';
    if (status === 'Released') action = 'Released';
    else if (status === 'Scrapped') action = 'Scrapped';
    else if (status === 'Returned') action = 'Returned';
    
    // Actualizar cuarentena
    const updateFields = ['updated_at = NOW()'];
    const updateValues = [];
    
    if (status) {
      updateFields.push('status = ?');
      updateValues.push(status);
      
      if (status !== 'InQuarantine') {
        updateFields.push('closed_at = NOW()', 'closed_by_id = ?', 'closed_by_name = ?');
        updateValues.push(userId, userName);
      }
    }
    
    updateValues.push(id);
    await pool.query(`UPDATE quarantine SET ${updateFields.join(', ')} WHERE id = ?`, updateValues);
    
    // Registrar en historial
    await pool.query(
      `INSERT INTO quarantine_history (quarantine_id, action, old_status, new_status, comments, action_by_id, action_by_name)
       VALUES (?, ?, ?, ?, ?, ?, ?)`,
      [id, action, oldStatus, status || oldStatus, comments, userId, userName]
    );
    
    // Si se libera, quitar marca de cuarentena
    if (status === 'Released') {
      await pool.query(
        `UPDATE control_material_almacen SET en_cuarentena = 0 WHERE codigo_material_recibido = ?`,
        [codigo]
      );
    }
    
    // Si se desecha o devuelve, sacar del inventario
    if (status === 'Scrapped' || status === 'Returned') {
      // Quitar marca de cuarentena y marcar como desecho
      await pool.query(
        `UPDATE control_material_almacen SET en_cuarentena = 0, estado_desecho = 1 WHERE codigo_material_recibido = ?`,
        [codigo]
      );
      
      // Actualizar total_salida para que stock_actual quede en 0 (stock_actual es columna generada)
      await pool.query(
        `UPDATE inventario_lotes SET total_salida = total_entrada WHERE codigo_material_recibido = ?`,
        [codigo]
      );
    }
    
    res.json({ success: true, message: 'Quarantine updated' });
  } catch (err) { next(err); }
});

// POST - Agregar comentario a cuarentena
app.post('/api/quarantine/:id/comment', async (req, res, next) => {
  try {
    const { id } = req.params;
    const { comments, userId, userName } = req.body;
    
    // Verificar que existe
    const [current] = await pool.query(`SELECT status FROM quarantine WHERE id = ?`, [id]);
    if (current.length === 0) {
      return res.status(404).json({ error: 'Quarantine item not found' });
    }
    
    // Registrar comentario en historial
    await pool.query(
      `INSERT INTO quarantine_history (quarantine_id, action, old_status, new_status, comments, action_by_id, action_by_name)
       VALUES (?, 'CommentAdded', ?, ?, ?, ?, ?)`,
      [id, current[0].status, current[0].status, comments, userId, userName]
    );
    
    // Actualizar timestamp
    await pool.query(`UPDATE quarantine SET updated_at = NOW() WHERE id = ?`, [id]);
    
    res.json({ success: true, message: 'Comment added' });
  } catch (err) { next(err); }
});

// ============================================
// Middleware de errores
// ============================================
app.use((err, req, res, next) => {
  console.error('Error:', err.message);
  res.status(500).json({ error: 'Error interno del servidor', details: err.message });
});

