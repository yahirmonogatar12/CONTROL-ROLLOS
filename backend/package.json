{
  "name": "material-warehousing-api",
  "version": "1.0.0",
  "description": "Backend API para Control de Material de Almacén",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --targets node18-win-x64 --output dist/backend-server.exe"
  },
  "pkg": {
    "assets": [
      "config/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  }
}
